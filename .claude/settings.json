{
  "permissions": {
    "allow": [
      "Edit(*)",
      "Write(*)",
      "WebFetch(domain:*)",
      "WebSearch",
      "mcp__*"
    ],
    "deny": [],
    "ask": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(shred *)",
      "Bash(unlink *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(fdisk *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(npm *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(docker *)",
      "Bash(kubectl *)",
      "Bash(wget *)",
      "Bash(kill *)",
      "Bash(killall *)",
      "Bash(pkill *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e 'let d=\"\";process.stdin.on(\"data\",c=>d+=c);process.stdin.on(\"end\",()=>{const j=JSON.parse(d);const f=(j.tool_input||{}).file_path||\"\";if(!f||!/\\.(ts|tsx|js|jsx|mjs|cjs|mts)$/.test(f))return;require(\"child_process\").spawnSync(\"npx\",[\"eslint\",\"--fix\",f],{stdio:\"inherit\"});})' || true",
            "statusMessage": "ESLint auto-fix..."
          }
        ]
      }
    ]
  }
}
